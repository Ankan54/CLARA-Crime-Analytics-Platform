# Backend API base URL. MUST include the /api/v1 suffix.
# Leave UNSET to use vite.config.ts's dev proxy (same-origin /api and /ws).
# Set only when pointing at a remote or non-proxied backend.
#VITE_API_BASE_URL=http://localhost:9000/api/v1

# Optional WebSocket origin override (production / AppSail builds).
# Local Vite uses same-origin /ws via the proxy when this is unset.
#VITE_WS_BASE_URL=https://your-backend-host.example

{
  "appsail": [
    {
      "name": "ksp-catalyst-backend",
      "source": "backend",
      "env_variables": {
        "X_ZOHO_CATALYST_ACCOUNTS_URL": "https://accounts.zohoportal.in",
        "X_ZOHO_CATALYST_CONSOLE_URL": "https://api.catalyst.zoho.in",
        "X_ZOHO_STRATUS_RESOURCE_SUFFIX": ".zohostratus.in",
        "ZOHO_CATALYST_PROJECT_ID": "your_project_id",
        "ZOHO_CATALYST_PROJECT_KEY": "your_project_key",
        "ZOHO_CATALYST_ENVIRONMENT": "Development",

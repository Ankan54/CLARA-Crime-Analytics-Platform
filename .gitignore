# Dotfiles — ignore all, then negate the ones that must be tracked
.*
!.gitignore
!.catalystrc

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pdf
# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# Type checkers & linters
.mypy_cache/
.ruff_cache/
.pytype/

# Environment variables & secrets
.env
.env.*
!.env.example
!**/.env.example
*.pem
*.key
secrets.json
credentials.json
catalyst.json
backend/app-config.json
AGENTS.md

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDEs & editors
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/

# Logs
*.log
logs/

# Data & model artifacts (uncomment or adjust as needed)
# *.csv
# *.parquet
# *.pkl
# *.pickle
# *.h5
# *.hdf5
# *.joblib
# *.model
# data/raw/
# data/processed/
# models/


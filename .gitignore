# Dotfiles — ignore all, then negate the ones that must be tracked
.*
!.gitignore
!.catalystrc
!.env.example
!**/.env.example
!frontend/.gitignore
!frontend/.oxlintrc.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

# scripts/ — keep only wipe + historical reload + demo reset
/scripts/**
!/scripts/wipe_all_data.py
!/scripts/reset_and_reload_historical.py
!/scripts/reset_demo_data.py

# Ingest function local helpers (not needed to run)
